{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "GPU Inference Platform",
  "uid": "gpu-inference",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(api_requests_total[1m])",
          "legendFormat": "{{endpoint}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "API p50 / p95 Latency",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.5, rate(api_request_duration_seconds_bucket[1m])) * 1000",
          "legendFormat": "p50 ms"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, rate(api_request_duration_seconds_bucket[1m])) * 1000",
          "legendFormat": "p95 ms"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.99, rate(api_request_duration_seconds_bucket[1m])) * 1000",
          "legendFormat": "p99 ms"
        }
      ]
    },
    {
      "id": 3,
      "title": "API Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 6},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(api_requests_total{status=~\"5..\"}[1m]) / rate(api_requests_total[1m])",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Requests",
      "type": "stat",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 6},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "api_active_requests",
          "legendFormat": "active"
        }
      ]
    },
    {
      "id": 5,
      "title": "Triton Inference Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(nv_inference_request_success[1m])",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Triton Queue + Compute Time (μs)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(nv_inference_queue_duration_us[1m])",
          "legendFormat": "queue μs {{model}}"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(nv_inference_compute_infer_duration_us[1m])",
          "legendFormat": "compute μs {{model}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "GPU Utilization %",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 18},
      "fieldConfig": {"defaults": {"min": 0, "max": 100, "unit": "percent"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "GPU Memory Used (MiB)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 18},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "GPU {{gpu}} used MiB"
        }
      ]
    },
    {
      "id": 9,
      "title": "GPU Memory Bandwidth %",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 18},
      "fieldConfig": {"defaults": {"min": 0, "max": 100, "unit": "percent"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "DCGM_FI_DEV_MEM_COPY_UTIL",
          "legendFormat": "GPU {{gpu}} mem BW"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "pluginId": "prometheus"
      }
    ]
  }
}
